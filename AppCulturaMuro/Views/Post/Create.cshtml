@model AppCulturaMuro.ViewModels.CreatePostViewModel
@{
    ViewBag.Title = "New Post";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="cm-create-wrap">
    <h1 class="cm-page-title">New post</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="cm-alert-error">@Html.ValidationSummary(false)</div>
    }

    <div class="cm-card" style="padding:1.75rem;">
        @using (Html.BeginForm("Create", "Post", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <div class="cm-form-group">
                <label class="cm-form-label">Title (optional)</label>
                @Html.TextBoxFor(m => m.Title, new { @class = "cm-form-control", placeholder = "Give it a name…" })
            </div>

            <div class="cm-form-group">
                <label class="cm-form-label">What's on your mind?</label>
                @Html.TextAreaFor(m => m.Content, new { @class = "cm-form-control", rows = "5", placeholder = "Share something cultural…", style = "resize:vertical;" })
            </div>

            <div class="cm-form-group">
                <label class="cm-form-label">Image (optional)</label>
                <input type="file" name="Image" accept="image/*"
                       class="cm-form-control" id="imageInput" />
                <img id="imagePreview" src="#" alt="preview"
                     style="display:none;margin-top:.75rem;max-height:220px;
                            border-radius:12px;object-fit:cover;width:100%;" />
            </div>

            <div style="display:flex;gap:.75rem;margin-top:1.25rem;">
                <a href="/Home/Index"
                   style="flex:1;text-align:center;padding:.8rem;
                          border:1.5px solid var(--border);border-radius:var(--radius-sm);
                          font-size:14px;color:var(--text);text-decoration:none;
                          font-family:var(--font-head);font-weight:600;">
                    Cancel
                </a>
                <button type="submit" class="cm-btn-primary" style="flex:2;width:auto;">
                    Publish →
                </button>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
    // Image preview before upload
    document.getElementById('imageInput').addEventListener('change', function (e) {
        var file = e.target.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function (ev) {
            var img = document.getElementById('imagePreview');
            img.src = ev.target.result;
            img.style.display = 'block';
        };
        reader.readAsDataURL(file);
    });
    </script>
}