@model List<AppCulturaMuro.Models.Post>
@{
    ViewBag.Title = "Feed";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="cm-feed-wrap">
    <div class="cm-feed-header">
        <h1 class="cm-feed-title">Latest posts</h1>
        <span class="cm-feed-count">@Model.Count posts</span>
    </div>

    @if (!Model.Any())
    {
        <div class="cm-empty">
            <i class="bi bi-journal-x" style="font-size:2rem;display:block;margin-bottom:.5rem;"></i>
            Nothing here yet. Be the first to post!
        </div>
    }
    else
    {
        foreach (var post in Model)
        {
            var formId = "delete-form-" + post.Id;
            <article class="cm-post-card">
                <div class="cm-post-accent"></div>
                <div class="cm-post-inner">
                    <div class="cm-card-header">
                        <div class="cm-avatar-sm">
                            @post.User.Username.Substring(0, 1).ToUpper()
                        </div>
                        <div>
                            <div class="cm-username">@@@post.User.Username</div>
                            <div class="cm-time">
                                <span class="cm-relative-time" data-date="@post.CreatedAt.ToString("o")"></span>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(post.ImageUrl))
                    {
                        <img src="@post.ImageUrl" class="cm-card-img" alt="post image" />
                    }

                    <div class="cm-card-body">
                        @if (!string.IsNullOrEmpty(post.Title))
                        {
                            <div class="cm-card-title">@post.Title</div>
                        }
                        @if (!string.IsNullOrEmpty(post.Content))
                        {
                            <p class="cm-card-text">@post.Content</p>
                        }
                    </div>

                    <div class="cm-card-footer">
                        <div style="display:flex;align-items:center;gap:1rem;">
                            <a href="/Post/Detail/@post.Id" class="cm-comment-link">
                                <i class="bi bi-chat"></i>
                                @post.Comments.Count comment@(post.Comments.Count != 1 ? "s" : "")
                            </a>
                            <span class="cm-read-time">
                                <i class="bi bi-book"></i>
                                @(Math.Max(1, (post.Content ?? "").Split(' ').Length / 200)) min read
                            </span>
                        </div>

                        @if ((int?)Session["UserId"] == post.UserId)
                        {
                            using (Html.BeginForm("Delete", "Post", new { id = post.Id }, FormMethod.Post, new { id = formId }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="button"
                                        onclick="showDeleteModal('@formId')"
                                        class="cm-delete-btn">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        }
                    </div>
                </div>
            </article>
        }
    }
</div>